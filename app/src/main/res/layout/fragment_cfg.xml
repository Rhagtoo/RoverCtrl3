<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connection Settings"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect phone to WiFi 'RoverAP' (password: rover12345)"
            android:textColor="#80CBC4"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_connection_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disconnected"
            android:textColor="#FF5252"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- ── Rover ─────────────────────────────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ROVER (ESP32-S3 — AP Host)"
            android:textColor="#00E676"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Rover IP" android:textColor="#AAAAAA" android:textSize="12sp" />
        <EditText android:id="@+id/et_rover_ip"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:inputType="text" android:textColor="#FFFFFF" android:background="#333333"
            android:padding="8dp" android:hint="192.168.4.1" android:textColorHint="#666666"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Command Port" android:textColor="#AAAAAA" android:textSize="12sp" />
        <EditText android:id="@+id/et_cmd_port"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:inputType="number" android:textColor="#FFFFFF" android:background="#333333"
            android:padding="8dp" android:hint="4210" android:textColorHint="#666666"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Telemetry Port" android:textColor="#AAAAAA" android:textSize="12sp" />
        <EditText android:id="@+id/et_tel_port"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:inputType="number" android:textColor="#FFFFFF" android:background="#333333"
            android:padding="8dp" android:hint="4211" android:textColorHint="#666666"
            android:layout_marginBottom="16dp" />

        <!-- ── Xiao ─────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XIAO SENSE (PAN/TILT + CAMERA — Client)"
            android:textColor="#FFAB00"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Xiao IP" android:textColor="#AAAAAA" android:textSize="12sp" />
        <EditText android:id="@+id/et_xiao_ip"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:inputType="text" android:textColor="#FFFFFF" android:background="#333333"
            android:padding="8dp" android:hint="192.168.4.2" android:textColorHint="#666666"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Xiao Servo Port (UDP)" android:textColor="#AAAAAA" android:textSize="12sp" />
        <EditText android:id="@+id/et_xiao_port"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:inputType="number" android:textColor="#FFFFFF" android:background="#333333"
            android:padding="8dp" android:hint="4210" android:textColorHint="#666666"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Xiao Camera Stream Port (HTTP MJPEG)" android:textColor="#AAAAAA" android:textSize="12sp" />
        <EditText android:id="@+id/et_xiao_stream_port"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:inputType="number" android:textColor="#FFFFFF" android:background="#333333"
            android:padding="8dp" android:hint="81" android:textColorHint="#666666"
            android:layout_marginBottom="16dp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btn_connect"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="2"
                android:text="Connect" android:textSize="16sp" android:layout_marginEnd="8dp" />

            <Button android:id="@+id/btn_reset"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:text="Reset" android:textSize="14sp" android:backgroundTint="#555555" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v2.6 AP Mode — Rover creates WiFi hotspot"
            android:textColor="#666666"
            android:textSize="11sp"
            android:layout_marginTop="8dp" />

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ── TILT CALIBRATION ──────────────────────────────────────────── -->
        <!-- ═══════════════════════════════════════════════════════════════ -->

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginTop="20dp" android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TILT CALIBRATION"
            android:textColor="#E040FB"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Virtual angle / target / PWM (live from turret)"
            android:textColor="#888888"
            android:textSize="11sp"
            android:layout_marginBottom="8dp" />

        <!-- Live status line -->
        <TextView
            android:id="@+id/tv_tilt_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-- not connected --"
            android:textColor="#888888"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center"
            android:background="#222222"
            android:padding="10dp"
            android:layout_marginBottom="10dp" />

        <!-- Set virtual angle reference (no movement) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Virtual °:" android:textColor="#AAAAAA" android:textSize="12sp"
                android:layout_marginEnd="8dp" />
            <EditText android:id="@+id/et_vcal_angle"
                android:layout_width="72dp" android:layout_height="40dp"
                android:text="90" android:textColor="#FFFFFF" android:textSize="14sp"
                android:inputType="numberDecimal" android:gravity="center"
                android:background="#333333" android:padding="6dp"
                android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btn_vcal_set"
                android:layout_width="wrap_content" android:layout_height="40dp"
                android:text="Set" android:textSize="12sp"
                android:backgroundTint="#7C4DFF" />
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Camera stays put" android:textColor="#666666" android:textSize="10sp" />
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ── TILT PARAMETERS (runtime tunable) ────────────────────────── -->
        <!-- ═══════════════════════════════════════════════════════════════ -->

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginTop="12dp" android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TILT PARAMETERS"
            android:textColor="#E040FB"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adjust CR servo model. Changes apply instantly. Save to persist."
            android:textColor="#888888"
            android:textSize="10sp"
            android:layout_marginBottom="12dp" />

        <!-- Neutral PWM -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="Neutral PWM" android:textColor="#AAAAAA" android:textSize="12sp" />
            <TextView android:id="@+id/tv_tp_neutral_val" android:layout_width="40dp"
                android:layout_height="wrap_content" android:text="90" android:textColor="#FFFFFF"
                android:textSize="12sp" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/sb_tp_neutral"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:min="70" android:max="110" android:progress="90"
            android:layout_marginBottom="8dp" />

        <!-- Max Speed -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="Max Speed" android:textColor="#AAAAAA" android:textSize="12sp" />
            <TextView android:id="@+id/tv_tp_speed_val" android:layout_width="40dp"
                android:layout_height="wrap_content" android:text="60" android:textColor="#FFFFFF"
                android:textSize="12sp" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/sb_tp_speed"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:min="10" android:max="90" android:progress="60"
            android:layout_marginBottom="8dp" />

        <!-- DPS Camera Up -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="°/s Cam ↑" android:textColor="#AAAAAA" android:textSize="12sp" />
            <TextView android:id="@+id/tv_tp_dps_up_val" android:layout_width="40dp"
                android:layout_height="wrap_content" android:text="70" android:textColor="#FFFFFF"
                android:textSize="12sp" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/sb_tp_dps_up"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:min="10" android:max="500" android:progress="70"
            android:layout_marginBottom="8dp" />

        <!-- DPS Camera Down -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="°/s Cam ↓" android:textColor="#AAAAAA" android:textSize="12sp" />
            <TextView android:id="@+id/tv_tp_dps_dn_val" android:layout_width="40dp"
                android:layout_height="wrap_content" android:text="90" android:textColor="#FFFFFF"
                android:textSize="12sp" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/sb_tp_dps_dn"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:min="10" android:max="500" android:progress="90"
            android:layout_marginBottom="8dp" />

        <!-- Deadband -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="Deadband °" android:textColor="#AAAAAA" android:textSize="12sp" />
            <TextView android:id="@+id/tv_tp_deadband_val" android:layout_width="40dp"
                android:layout_height="wrap_content" android:text="5" android:textColor="#FFFFFF"
                android:textSize="12sp" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/sb_tp_deadband"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:min="1" android:max="20" android:progress="5"
            android:layout_marginBottom="12dp" />

        <!-- Test + Save buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="4dp">

            <!-- Test duration selector -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Test:" android:textColor="#AAAAAA" android:textSize="11sp"
                android:layout_marginEnd="4dp" />
            <RadioGroup android:id="@+id/rg_tcal_duration"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="horizontal" android:gravity="center">
                <RadioButton android:id="@+id/rb_tcal_05s" android:layout_width="wrap_content"
                    android:layout_height="32dp" android:text="0.5s" android:textSize="11sp"
                    android:textColor="#AAAAAA" android:checked="true" android:minWidth="0dp"
                    android:paddingStart="4dp" android:paddingEnd="8dp" />
                <RadioButton android:id="@+id/rb_tcal_1s" android:layout_width="wrap_content"
                    android:layout_height="32dp" android:text="1s" android:textSize="11sp"
                    android:textColor="#AAAAAA" android:minWidth="0dp"
                    android:paddingStart="4dp" android:paddingEnd="8dp" />
                <RadioButton android:id="@+id/rb_tcal_2s" android:layout_width="wrap_content"
                    android:layout_height="32dp" android:text="2s" android:textSize="11sp"
                    android:textColor="#AAAAAA" android:minWidth="0dp"
                    android:paddingStart="4dp" android:paddingEnd="8dp" />
            </RadioGroup>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btn_tcal_up"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:text="Test ↑" android:textSize="12sp"
                android:backgroundTint="#1565C0" android:layout_marginEnd="4dp" />

            <Button android:id="@+id/btn_tcal_dn"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:text="Test ↓" android:textSize="12sp"
                android:backgroundTint="#1565C0" android:layout_marginEnd="4dp" />

            <Button android:id="@+id/btn_tp_save"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:text="Save ESP" android:textSize="12sp"
                android:backgroundTint="#00695C" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_tcal_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#80CBC4"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- After test: enter actual degrees moved -->
        <LinearLayout
            android:id="@+id/ll_tcal_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Actual °:" android:textColor="#AAAAAA" android:textSize="12sp"
                android:layout_marginEnd="8dp" />
            <EditText android:id="@+id/et_tcal_actual"
                android:layout_width="72dp" android:layout_height="40dp"
                android:text="" android:textColor="#FFFFFF" android:textSize="14sp"
                android:inputType="numberDecimal" android:gravity="center"
                android:background="#333333" android:padding="6dp"
                android:hint="°" android:textColorHint="#555555"
                android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btn_tcal_apply"
                android:layout_width="wrap_content" android:layout_height="40dp"
                android:text="Apply" android:textSize="12sp"
                android:backgroundTint="#00695C" android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btn_tcal_cancel"
                android:layout_width="wrap_content" android:layout_height="40dp"
                android:text="Cancel" android:textSize="12sp"
                android:backgroundTint="#555555" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1) Set Virtual=90, position camera forward\n2) Start with 0.5s test, increase if too small\n3) Enter actual degrees → auto-calculates °/s\n⚠ High speed + long test = full rotation = wire wrap!"
            android:textColor="#666666"
            android:textSize="10sp"
            android:layout_marginBottom="4dp" />

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ── OTA FIRMWARE UPDATE ──────────────────────────────────────── -->
        <!-- ═══════════════════════════════════════════════════════════════ -->

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginTop="20dp" android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OTA FIRMWARE UPDATE"
            android:textColor="#FF6D00"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Target device" android:textColor="#AAAAAA" android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <RadioGroup android:id="@+id/rg_ota_target"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <RadioButton android:id="@+id/rb_ota_rover"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Rover (192.168.4.1)" android:textColor="#FFFFFF" android:textSize="12sp"
                android:checked="true" />
            <RadioButton android:id="@+id/rb_ota_turret"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Turret (192.168.4.2)" android:textColor="#FFFFFF" android:textSize="12sp" />
        </RadioGroup>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <Button android:id="@+id/btn_select_bin"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:text="Select .bin" android:textSize="13sp"
                android:backgroundTint="#444444" android:layout_marginEnd="8dp" />
            <TextView android:id="@+id/tv_ota_filename"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="2"
                android:text="No file selected" android:textColor="#888888" android:textSize="12sp"
                android:gravity="center_vertical" android:ellipsize="start" android:singleLine="true" />
        </LinearLayout>

        <ProgressBar android:id="@+id/pb_ota"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="8dp"
            android:max="100" android:progress="0" android:layout_marginBottom="4dp"
            android:visibility="invisible" />

        <TextView android:id="@+id/tv_ota_status"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="" android:textColor="#AAAAAA" android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btn_ota_upload"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Flash Firmware" android:textSize="15sp"
            android:enabled="false" android:backgroundTint="#BF360C" />

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ── JOYSTICK SENSITIVITY ──────────────────────────────────────── -->
        <!-- ═══════════════════════════════════════════════════════════════ -->

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginTop="20dp" android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JOYSTICK SENSITIVITY"
            android:textColor="#00BCD4"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Drive Speed -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
            <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                android:text="Drive Speed" android:textColor="#AAAAAA" android:textSize="12sp" />
            <TextView android:id="@+id/tv_drive_speed_val" android:layout_width="40dp"
                android:layout_height="wrap_content" android:text="1.0x" android:textColor="#FFFFFF"
                android:textSize="12sp" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/sb_drive_speed"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:max="19" android:progress="9" android:layout_marginBottom="12dp" />

        <!-- Drive Steer -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
            <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                android:text="Drive Steer" android:textColor="#AAAAAA" android:textSize="12sp" />
            <TextView android:id="@+id/tv_drive_steer_val" android:layout_width="40dp"
                android:layout_height="wrap_content" android:text="1.0x" android:textColor="#FFFFFF"
                android:textSize="12sp" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/sb_drive_steer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:max="19" android:progress="9" android:layout_marginBottom="12dp" />

        <!-- Cam Pan -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
            <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                android:text="Camera Pan" android:textColor="#AAAAAA" android:textSize="12sp" />
            <TextView android:id="@+id/tv_cam_pan_val" android:layout_width="40dp"
                android:layout_height="wrap_content" android:text="1.0x" android:textColor="#FFFFFF"
                android:textSize="12sp" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/sb_cam_pan"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:max="19" android:progress="9" android:layout_marginBottom="12dp" />

        <!-- Cam Tilt -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
            <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                android:text="Camera Tilt" android:textColor="#AAAAAA" android:textSize="12sp" />
            <TextView android:id="@+id/tv_cam_tilt_val" android:layout_width="40dp"
                android:layout_height="wrap_content" android:text="1.0x" android:textColor="#FFFFFF"
                android:textSize="12sp" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/sb_cam_tilt"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:max="19" android:progress="9" android:layout_marginBottom="8dp" />

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ── TRACKING TUNING (YOLO anti-jitter) ─────────────────────── -->
        <!-- ═══════════════════════════════════════════════════════════════ -->

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginTop="12dp" android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TRACKING TUNING"
            android:textColor="#E040FB"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adjust YOLO tracking smoothness. Takes effect immediately."
            android:textColor="#888888"
            android:textSize="10sp"
            android:layout_marginBottom="12dp" />

        <!-- Deadzone -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="Deadzone" android:textColor="#AAAAAA" android:textSize="12sp" />
            <TextView android:id="@+id/tv_trk_dz_val" android:layout_width="40dp"
                android:layout_height="wrap_content" android:text="4%" android:textColor="#FFFFFF"
                android:textSize="12sp" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/sb_trk_deadzone"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:min="1" android:max="15" android:progress="4"
            android:layout_marginBottom="8dp" />

        <!-- Expo curve -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="Expo curve" android:textColor="#AAAAAA" android:textSize="12sp" />
            <TextView android:id="@+id/tv_trk_expo_val" android:layout_width="40dp"
                android:layout_height="wrap_content" android:text="2.0" android:textColor="#FFFFFF"
                android:textSize="12sp" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/sb_trk_expo"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:min="10" android:max="30" android:progress="20"
            android:layout_marginBottom="8dp" />

        <!-- Rate limit -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="Rate limit" android:textColor="#AAAAAA" android:textSize="12sp" />
            <TextView android:id="@+id/tv_trk_rate_val" android:layout_width="40dp"
                android:layout_height="wrap_content" android:text="8" android:textColor="#FFFFFF"
                android:textSize="12sp" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/sb_trk_rate"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:min="2" android:max="30" android:progress="8"
            android:layout_marginBottom="8dp" />

        <!-- Model selection -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                android:text="Model" android:textColor="#AAAAAA" android:textSize="12sp" />
            <Spinner android:id="@+id/spinner_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#333333"
                android:padding="8dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
