<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connection Settings"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect phone to WiFi 'RoverAP' (password: rover12345)"
            android:textColor="#80CBC4"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <!-- Статус -->
        <TextView
            android:id="@+id/tv_connection_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disconnected"
            android:textColor="#FF5252"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- ── Rover ─────────────────────────────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ROVER (XIAO ESP32S3 — AP Host)"
            android:textColor="#00E676"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rover IP"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />
        <EditText
            android:id="@+id/et_rover_ip"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:inputType="text"
            android:textColor="#FFFFFF"
            android:background="#333333"
            android:padding="8dp"
            android:hint="192.168.4.1"
            android:textColorHint="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Command Port"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />
        <EditText
            android:id="@+id/et_cmd_port"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:background="#333333"
            android:padding="8dp"
            android:hint="4210"
            android:textColorHint="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Telemetry Port"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />
        <EditText
            android:id="@+id/et_tel_port"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:background="#333333"
            android:padding="8dp"
            android:hint="4211"
            android:textColorHint="#666666"
            android:layout_marginBottom="16dp" />

        <!-- ── Xiao (Pan/Tilt серво + камера) ─────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XIAO SENSE (PAN/TILT + CAMERA — Client)"
            android:textColor="#FFAB00"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xiao IP"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />
        <EditText
            android:id="@+id/et_xiao_ip"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:inputType="text"
            android:textColor="#FFFFFF"
            android:background="#333333"
            android:padding="8dp"
            android:hint="192.168.4.2"
            android:textColorHint="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xiao Servo Port (UDP)"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />
        <EditText
            android:id="@+id/et_xiao_port"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:background="#333333"
            android:padding="8dp"
            android:hint="4210"
            android:textColorHint="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xiao Camera Stream Port (HTTP MJPEG)"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />
        <EditText
            android:id="@+id/et_xiao_stream_port"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:background="#333333"
            android:padding="8dp"
            android:hint="81"
            android:textColorHint="#666666"
            android:layout_marginBottom="16dp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_connect"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:text="Connect"
                android:textSize="16sp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Reset"
                android:textSize="14sp"
                android:backgroundTint="#555555" />

        </LinearLayout>

        <!-- Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v2.0 AP Mode — Rover creates WiFi hotspot"
            android:textColor="#666666"
            android:textSize="11sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
