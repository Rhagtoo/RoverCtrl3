<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

    <!-- Слой 1: Карта на весь фон -->
    <org.rhanet.roverctrl.ui.control.RoverVizView
        android:id="@+id/rover_viz"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Слой 2: PiP (top-left) -->
    <FrameLayout
        android:id="@+id/pip_container"
        android:layout_width="180dp"
        android:layout_height="135dp"
        android:layout_gravity="top|start"
        android:layout_margin="4dp"
        android:background="#55000000"
        android:visibility="gone">
        <ImageView android:id="@+id/iv_turret_pip"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:scaleType="centerCrop" android:contentDescription="Turret" />
        <TextView android:id="@+id/tv_turret_fps"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="top|end" android:text="--"
            android:textColor="#00E676" android:textSize="10sp" android:textStyle="bold"
            android:padding="2dp" android:background="#80000000" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="top|start" android:text="TURRET"
            android:textColor="#FFAB00" android:textSize="9sp" android:textStyle="bold"
            android:padding="2dp" android:background="#80000000" />
        <View android:layout_width="1dp" android:layout_height="18dp"
            android:layout_gravity="center" android:background="#80FF5252" />
        <View android:layout_width="18dp" android:layout_height="1dp"
            android:layout_gravity="center" android:background="#80FF5252" />
    </FrameLayout>

    <!-- Слой 3: HUD телеметрия (top, полная ширина) -->
    <LinearLayout
        android:id="@+id/hud_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:background="#CC111111"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp">

        <!-- Строка 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BAT:" android:textColor="#888" android:textSize="12sp" />
            <TextView android:id="@+id/tv_bat"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textColor="#00E676" android:textSize="12sp"
                android:textStyle="bold" android:paddingStart="2dp" android:paddingEnd="10dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SPD:" android:textColor="#888" android:textSize="12sp" />
            <TextView android:id="@+id/tv_spd"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textColor="#FFF" android:textSize="12sp"
                android:paddingStart="2dp" android:paddingEnd="10dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="YAW:" android:textColor="#888" android:textSize="12sp" />
            <TextView android:id="@+id/tv_yaw"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0°" android:textColor="#FFF" android:textSize="12sp"
                android:paddingStart="2dp" android:paddingEnd="10dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="RSSI:" android:textColor="#888" android:textSize="12sp" />
            <TextView android:id="@+id/tv_rssi"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textColor="#FFAB00" android:textSize="12sp"
                android:paddingStart="2dp" />
        </LinearLayout>

        <!-- Строка 2: одометрия -->
        <TextView android:id="@+id/tv_odom"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="X:0.00 Y:0.00 H:0° D:0.0m"
            android:textColor="#80CBC4" android:textSize="11sp" />
    </LinearLayout>

    <!-- Слой 4: Нижняя панель (джойстики + кнопки между ними) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center_vertical|bottom"
        android:padding="4dp">

        <!-- Левый джойстик -->
        <org.rhanet.roverctrl.ui.control.JoystickView
            android:id="@+id/joystick_drive"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:alpha="0.6" />

        <!-- Центральный блок: кнопки -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="4dp">

            <!-- Верхний ряд кнопок -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="3dp">
                <ToggleButton android:id="@+id/btn_laser"
                    android:layout_width="60dp" android:layout_height="28dp"
                    android:textOn="LASER" android:textOff="LASER"
                    android:textColor="#FFF" android:textSize="8sp"
                    android:background="#FF5252" android:layout_marginEnd="3dp" />
                <ToggleButton android:id="@+id/btn_gyro_tilt"
                    android:layout_width="60dp" android:layout_height="28dp"
                    android:textOn="GYRO" android:textOff="GYRO"
                    android:textColor="#FFF" android:textSize="8sp"
                    android:background="#7C4DFF" />
            </LinearLayout>

            <!-- Нижний ряд кнопок -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="3dp">
                <ToggleButton android:id="@+id/btn_pip"
                    android:layout_width="52dp" android:layout_height="28dp"
                    android:textOn="PiP" android:textOff="PiP"
                    android:textColor="#FFF" android:textSize="8sp"
                    android:background="#FF8F00" android:layout_marginEnd="3dp" />
                <ToggleButton android:id="@+id/btn_gear"
                    android:layout_width="60dp" android:layout_height="28dp"
                    android:textOn="GEAR1" android:textOff="GEAR2"
                    android:textColor="#FFF" android:textSize="8sp"
                    android:background="#1565C0" />
            </LinearLayout>

            <!-- Gyro debug -->
            <TextView android:id="@+id/tv_gyro_debug"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="#B388FF" android:textSize="9sp"
                android:visibility="gone" />

            <!-- Метки джойстиков -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="DRIVE" android:textColor="#55FFFFFF" android:textSize="10sp" />
                <TextView android:id="@+id/tv_cam_label"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="CAMERA" android:textColor="#55FFFFFF" android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Правый джойстик -->
        <org.rhanet.roverctrl.ui.control.JoystickView
            android:id="@+id/joystick_cam"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:alpha="0.6" />

    </LinearLayout>

</FrameLayout>
