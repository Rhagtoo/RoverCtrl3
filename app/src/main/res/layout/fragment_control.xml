<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_joystick_top"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.55" />

    <!-- ═══ Карта — весь фон ═══ -->
    <org.rhanet.roverctrl.ui.control.RoverVizView
        android:id="@+id/rover_viz"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══ PiP (top-left) ═══ -->
    <FrameLayout
        android:id="@+id/pip_container"
        android:layout_width="180dp"
        android:layout_height="135dp"
        android:background="#55000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="4dp">
        <ImageView android:id="@+id/iv_turret_pip"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:scaleType="centerCrop" android:contentDescription="Turret camera" />
        <TextView android:id="@+id/tv_turret_fps"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="--" android:textColor="#00E676" android:textSize="10sp"
            android:textStyle="bold" android:padding="2dp" android:background="#80000000"
            android:layout_gravity="top|end" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="TURRET" android:textColor="#FFAB00" android:textSize="9sp"
            android:textStyle="bold" android:padding="2dp" android:background="#80000000"
            android:layout_gravity="top|start" />
        <View android:layout_width="1dp" android:layout_height="18dp"
            android:background="#80FF5252" android:layout_gravity="center" />
        <View android:layout_width="18dp" android:layout_height="1dp"
            android:background="#80FF5252" android:layout_gravity="center" />
    </FrameLayout>

    <!-- ═══ HUD — горизонтальная полоса вверху ═══ -->
    <LinearLayout
        android:id="@+id/hud_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:background="#BB111111"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="BAT:" android:textColor="#888" android:textSize="10sp" />
        <TextView android:id="@+id/tv_bat" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="--" android:textColor="#00E676"
            android:textSize="10sp" android:textStyle="bold"
            android:paddingStart="2dp" android:paddingEnd="6dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SPD:" android:textColor="#888" android:textSize="10sp" />
        <TextView android:id="@+id/tv_spd" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="--" android:textColor="#FFF"
            android:textSize="10sp" android:paddingStart="2dp" android:paddingEnd="6dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="YAW:" android:textColor="#888" android:textSize="10sp" />
        <TextView android:id="@+id/tv_yaw" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="0°" android:textColor="#FFF"
            android:textSize="10sp" android:paddingStart="2dp" android:paddingEnd="6dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="RSSI:" android:textColor="#888" android:textSize="10sp" />
        <TextView android:id="@+id/tv_rssi" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="0" android:textColor="#FFAB00"
            android:textSize="10sp" android:paddingStart="2dp" android:paddingEnd="6dp" />
        <TextView android:id="@+id/tv_odom" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="X:0 Y:0 H:0°"
            android:textColor="#80CBC4" android:textSize="10sp" />
    </LinearLayout>

    <!-- ═══ Кнопки — горизонтальный ряд по центру ═══ -->
    <LinearLayout
        android:id="@+id/btn_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guide_joystick_top"
        android:layout_marginBottom="4dp">
        <ToggleButton android:id="@+id/btn_laser"
            android:layout_width="64dp" android:layout_height="30dp"
            android:textOn="LASER" android:textOff="LASER" android:textColor="#FFF"
            android:textSize="9sp" android:background="#FF5252" android:layout_marginEnd="4dp" />
        <ToggleButton android:id="@+id/btn_gyro_tilt"
            android:layout_width="64dp" android:layout_height="30dp"
            android:textOn="GYRO" android:textOff="GYRO" android:textColor="#FFF"
            android:textSize="9sp" android:background="#7C4DFF" android:layout_marginEnd="4dp" />
        <ToggleButton android:id="@+id/btn_pip"
            android:layout_width="56dp" android:layout_height="30dp"
            android:textOn="PiP" android:textOff="PiP" android:textColor="#FFF"
            android:textSize="9sp" android:background="#FF8F00" android:layout_marginEnd="4dp" />
        <ToggleButton android:id="@+id/btn_gear"
            android:layout_width="64dp" android:layout_height="30dp"
            android:textOn="GEAR1" android:textOff="GEAR2" android:textColor="#FFF"
            android:textSize="9sp" android:background="#1565C0" />
    </LinearLayout>

    <TextView android:id="@+id/tv_gyro_debug"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="" android:textColor="#B388FF" android:textSize="10sp"
        android:visibility="gone" android:background="#80000000" android:padding="2dp"
        app:layout_constraintTop_toBottomOf="@id/btn_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══ Джойстики — фиксированные 140dp, внизу ═══ -->
    <org.rhanet.roverctrl.ui.control.JoystickView
        android:id="@+id/joystick_drive"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:alpha="0.55"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="4dp" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="DRIVE" android:textColor="#55FFFFFF" android:textSize="10sp"
        app:layout_constraintBottom_toTopOf="@id/joystick_drive"
        app:layout_constraintStart_toStartOf="@id/joystick_drive"
        app:layout_constraintEnd_toEndOf="@id/joystick_drive" />

    <org.rhanet.roverctrl.ui.control.JoystickView
        android:id="@+id/joystick_cam"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:alpha="0.55"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp" />
    <TextView android:id="@+id/tv_cam_label"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="CAMERA" android:textColor="#55FFFFFF" android:textSize="10sp"
        app:layout_constraintBottom_toTopOf="@id/joystick_cam"
        app:layout_constraintStart_toStartOf="@id/joystick_cam"
        app:layout_constraintEnd_toEndOf="@id/joystick_cam" />

</androidx.constraintlayout.widget.ConstraintLayout>
