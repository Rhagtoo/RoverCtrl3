<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/controlFragment">

    <fragment
        android:id="@+id/controlFragment"
        android:name="org.rhanet.roverctrl.ui.control.ControlFragment"
        android:label="Control"
        tools:layout="@layout/fragment_control" />

    <fragment
        android:id="@+id/videoFragment"
        android:name="org.rhanet.roverctrl.ui.video.VideoFragment"
        android:label="Video"
        tools:layout="@layout/fragment_video">
        <action
            android:id="@+id/action_video_to_calibration"
            app:destination="@id/calibrationFragment" />
    </fragment>

    <fragment
        android:id="@+id/cfgFragment"
        android:name="org.rhanet.roverctrl.ui.cfg.CfgFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_cfg" />

    <fragment
        android:id="@+id/calibrationFragment"
        android:name="org.rhanet.roverctrl.ui.video.CalibrationFragment"
        android:label="Calibration"
        tools:layout="@layout/fragment_calibration" />

</navigation>
