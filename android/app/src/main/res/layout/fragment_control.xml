<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:padding="8dp">

    <!-- ═══ PiP: MJPEG стрим с камеры турели (XIAO Sense) ═══ -->
    <FrameLayout
        android:id="@+id/pip_container"
        android:layout_width="220dp"
        android:layout_height="165dp"
        android:background="#33FFFFFF"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="4dp">

        <ImageView
            android:id="@+id/iv_turret_pip"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Turret camera" />

        <!-- FPS + статус поверх PiP -->
        <TextView
            android:id="@+id/tv_turret_fps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#00E676"
            android:textSize="11sp"
            android:textStyle="bold"
            android:padding="3dp"
            android:background="#80000000"
            android:layout_gravity="top|end" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TURRET"
            android:textColor="#FFAB00"
            android:textSize="10sp"
            android:textStyle="bold"
            android:padding="3dp"
            android:background="#80000000"
            android:layout_gravity="top|start" />

        <!-- Крестик в центре PiP (ось лазера) -->
        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="#80FF5252"
            android:layout_gravity="center" />
        <View
            android:layout_width="20dp"
            android:layout_height="1dp"
            android:background="#80FF5252"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- Левый джойстик: Drive (скорость + руление) -->
    <org.rhanet.roverctrl.ui.control.JoystickView
        android:id="@+id/joystick_drive"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.30"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DRIVE"
        android:textColor="#888888"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/joystick_drive"
        app:layout_constraintStart_toStartOf="@id/joystick_drive"
        app:layout_constraintEnd_toEndOf="@id/joystick_drive"
        android:layout_marginTop="4dp" />

    <!-- Правый джойстик: Camera (pan/tilt) — скрывается в GYRO_TILT -->
    <org.rhanet.roverctrl.ui.control.JoystickView
        android:id="@+id/joystick_cam"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.30"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_cam_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CAMERA"
        android:textColor="#888888"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/joystick_cam"
        app:layout_constraintStart_toStartOf="@id/joystick_cam"
        app:layout_constraintEnd_toEndOf="@id/joystick_cam"
        android:layout_marginTop="4dp" />

    <!-- Центральная панель: HUD + лазер + гиро-тогл -->
    <LinearLayout
        android:id="@+id/hud_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="8dp"
        app:layout_constraintStart_toEndOf="@id/joystick_drive"
        app:layout_constraintEnd_toStartOf="@id/joystick_cam"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="8dp">

        <!-- Батарея -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BAT: "
                android:textColor="#888888"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_bat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#00E676"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Скорость -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPD: "
                android:textColor="#888888"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_spd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- RSSI -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RSSI: "
                android:textColor="#888888"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_rssi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 dBm"
                android:textColor="#FFAB00"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Одометрия -->
        <TextView
            android:id="@+id/tv_odom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="X:0.00 Y:0.00 H:0°"
            android:textColor="#80CBC4"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <!-- Yaw -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YAW: "
                android:textColor="#888888"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_yaw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0°"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Кнопка лазера -->
        <ToggleButton
            android:id="@+id/btn_laser"
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:textOn="LASER ON"
            android:textOff="LASER OFF"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="#FF5252"
            android:layout_marginBottom="6dp" />

        <!-- ═══ Gyro tilt toggle ═══ -->
        <ToggleButton
            android:id="@+id/btn_gyro_tilt"
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:textOn="GYRO ON"
            android:textOff="GYRO OFF"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="#7C4DFF"
            android:layout_marginBottom="4dp" />

        <!-- Кнопка PiP (показать/скрыть стрим турели) -->
        <ToggleButton
            android:id="@+id/btn_pip"
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:textOn="PiP ON"
            android:textOff="PiP OFF"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="#FF8F00"
            android:layout_marginBottom="4dp" />

        <!-- Gyro отладка -->
        <TextView
            android:id="@+id/tv_gyro_debug"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#B388FF"
            android:textSize="10sp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
