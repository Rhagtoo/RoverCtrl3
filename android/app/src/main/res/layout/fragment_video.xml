<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- CameraX Preview — живой видоискатель с камеры телефона -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/toolbar_video"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Overlay для крестика трекинга -->
    <org.rhanet.roverctrl.ui.video.TrackingOverlayView
        android:id="@+id/overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="@id/preview_view"
        app:layout_constraintBottom_toBottomOf="@id/preview_view"
        app:layout_constraintStart_toStartOf="@id/preview_view"
        app:layout_constraintEnd_toEndOf="@id/preview_view" />

    <!-- ═══ PiP: MJPEG стрим с камеры турели ═══ -->
    <FrameLayout
        android:id="@+id/pip_container_video"
        android:layout_width="180dp"
        android:layout_height="135dp"
        android:background="#33FFFFFF"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/toolbar_video"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="8dp">

        <ImageView
            android:id="@+id/iv_turret_pip_video"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Turret camera" />

        <TextView
            android:id="@+id/tv_turret_fps_video"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#00E676"
            android:textSize="10sp"
            android:textStyle="bold"
            android:padding="2dp"
            android:background="#80000000"
            android:layout_gravity="top|end" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TURRET"
            android:textColor="#FFAB00"
            android:textSize="9sp"
            android:textStyle="bold"
            android:padding="2dp"
            android:background="#80000000"
            android:layout_gravity="top|start" />

        <!-- Крестик -->
        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="#80FF5252"
            android:layout_gravity="center" />
        <View
            android:layout_width="16dp"
            android:layout_height="1dp"
            android:background="#80FF5252"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- FPS в углу -->
    <TextView
        android:id="@+id/tv_fps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 FPS"
        android:textColor="#00E676"
        android:textSize="14sp"
        android:textStyle="bold"
        android:padding="6dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="8dp" />

    <!-- Статус трекинга -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Manual"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:padding="6dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="8dp" />

    <!-- Нижняя панель -->
    <LinearLayout
        android:id="@+id/toolbar_video"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#222222"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tracking:"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <Spinner
            android:id="@+id/spinner_mode"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="#333333"
            android:popupBackground="#333333" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- PiP toggle -->
        <ToggleButton
            android:id="@+id/btn_pip_video"
            android:layout_width="60dp"
            android:layout_height="32dp"
            android:textOn="PiP"
            android:textOff="PiP"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:background="#FF8F00"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_calibrate"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Calibrate"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
